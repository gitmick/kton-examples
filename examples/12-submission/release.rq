# The release gate as ONE query over the merged submission graph (foton PROV lineage + every
# attestation as a nanopublication). This file is STANDARD SPARQL - it parses and runs unmodified in
# any compliant engine (no #TRUSTED# string surgery, no whole-store-union dependency; see release.py).
# It is bound to THIS submission: ?fit (the estimation activity) and ?head (the signed submission head)
# are supplied as query bindings; ?env is DERIVED from the graph (?fit nk:environment ?env). The trust
# root is DATA (?a a nk:TrustedAuthority), not a placeholder. So every condition is ABOUT this
# submission - an unrelated pass/qualify/review elsewhere cannot satisfy the gate. Each UNION branch
# yields one satisfied release-condition label; the harness passes only if every required one appears.
PREFIX gxp:  <https://kton.dev/v/gxp/>
PREFIX pmx:  <https://kton.dev/v/pmx/>
PREFIX nk:   <https://kton.dev/v/>
PREFIX lab:  <https://kton.dev/v/lab/>
PREFIX sec:  <https://w3id.org/security#>
PREFIX prov: <http://www.w3.org/ns/prov#>

SELECT DISTINCT ?condition WHERE {
  {
    # ?env is DERIVED FROM THE GRAPH: the fit declares its environment as a triple (nk:environment,
    # emitted by `plankton export --rdf` from the foton's COVERED protocol descriptor). No out-of-band
    # base64 decode of the DSSE - a pure SPARQL consumer binds it here (rdf-interop F2).
    ?fit nk:environment ?env .
    ?env gxp:validation-performed ?o . ?o nk:outcome "pass" .
    BIND("tool-validated" AS ?condition)
  } UNION {
    # not a NAKED binding: the qualification must (1) bind to THIS fit's env, and (2) cite a
    # fulfilment foton that actually consumed that env-spectrum - a re-derivable spectrum check,
    # not a bare "3/3" assertion. A qualifies-as with no fulfilment, or one whose fulfilment foton
    # never took this spectrum as input, does not satisfy the gate.
    ?fit nk:environment ?env .
    ?x nk:qualifies-as ?bag .
    ?bag lab:id ?env .
    ?bag lab:fulfilment ?chk .
    ?chk prov:used ?env .
    # ...and the cited check must be a FULL pass, not just "used": a 2/3 environment carries
    # membersFulfilled=2, membersTotal=3 and fails here. (A forged N==M is caught by the regulator's own
    # spectrum re-run, Act 8a, which aborts on a partial pass - "used" is not "passed".)
    ?bag lab:membersFulfilled ?nful .
    ?bag lab:membersTotal ?ntot .
    FILTER(?nful = ?ntot)
    BIND("env-qualified" AS ?condition)
  } UNION {
    ?fit prov:used ?m . ?m pmx:model-role ?o . ?o nk:role "final" .
    BIND("final-model" AS ?condition)
  } UNION {
    ?out prov:wasGeneratedBy ?fit . ?out nk:reproduces ?o . ?o nk:level-reached ?lvl . FILTER(?lvl IN ("L0", "L1"))
    BIND("reproduces" AS ?condition)
  } UNION {
    ?fit gxp:risk-accepted ?o .
    BIND("risk-accepted" AS ?condition)
  } UNION {
    ?head nk:submitted ?who .
    BIND("submission-signed" AS ?condition)
  } UNION {
    # NOT two distinct KEYS (three sock-puppet keys would pass), but two distinct PRINCIPALS, each
    # bound to its signing key by a sec:controller binding that is ITSELF signed by an authority the
    # verifier trusts. The trust root is DATA: release.py asserts `<authority> a nk:TrustedAuthority`
    # for each keyid in the verifier's OWN root (a COVERED input of the verdict), so the query matches
    # `?a a nk:TrustedAuthority` as an ordinary graph pattern - no query-string placeholder. A
    # self-issued binding - or a ring of mutual attestations (K2 vouches K3, K3 vouches K2) - is not
    # signed by a trusted authority, so it never counts. Example 07's rule: a binding is only worth the
    # authority that signed it.
    GRAPH ?g1 { ?fit gxp:reviewed ?o1 . ?o1 nk:outcome "pass" . } ?g1 prov:wasAttributedTo ?r1 .
    BIND(STRAFTER(STR(?r1), "kton.dev/agent/") AS ?kid1)
    GRAPH ?gb1 { ?k1 sec:controller ?cb1 . ?cb1 ?cbp1 ?p1 . } ?gb1 prov:wasAttributedTo ?a1 .
    FILTER(STRSTARTS(STRAFTER(STR(?k1), "kton.dev/o/"), ?kid1))
    ?a1 a nk:TrustedAuthority .
    GRAPH ?g2 { ?fit gxp:reviewed ?o2 . ?o2 nk:outcome "pass" . } ?g2 prov:wasAttributedTo ?r2 .
    BIND(STRAFTER(STR(?r2), "kton.dev/agent/") AS ?kid2)
    GRAPH ?gb2 { ?k2 sec:controller ?cb2 . ?cb2 ?cbp2 ?p2 . } ?gb2 prov:wasAttributedTo ?a2 .
    FILTER(STRSTARTS(STRAFTER(STR(?k2), "kton.dev/o/"), ?kid2))
    ?a2 a nk:TrustedAuthority .
    FILTER(?p1 != ?p2)
    # FOUR-EYES: a review is only "independent" if the reviewer is NOT the model's author.
    # (1) KEY granularity is the load-bearing check: the reviewer's SIGNING KEY must differ from the key
    # that signed the fit. The author is ANCHORED to the VERIFIED fit signer by reading it ONLY from the
    # trusted plankton-lineage graph (where `plankton export --rdf` emits prov:wasAttributedTo just for a
    # cryptographically-verified signer, tagged nk:signerVerified true). Reading ?rauthor from the merged
    # default graph was bypassable: an injected nekton claim <fit> prov:wasAttributedTo <garbage> gave
    # ?rauthor a second binding, so the author's self-review passed ?r1 != <garbage> (four-eyes bypass v2).
    # Graph-scoping makes ?rauthor the unique verified signer, so the exclusion is universal. (Excluding by
    # PRINCIPAL alone was ALSO bypassable via a key vouched under two DIDs - beat-gate-v3/F1 - hence key
    # granularity here; the agent IRIs ?r1/?r2/?rauthor ARE the keyids.)
    GRAPH <urn:kton:lineage> { ?fit prov:wasAttributedTo ?rauthor . ?fit nk:signerVerified true . }
    FILTER(?r1 != ?rauthor)
    FILTER(?r2 != ?rauthor)
    # (2) PRINCIPAL granularity, additionally: a DIFFERENT key bound to the author's SAME principal (the
    # same person signing with a second key) is also not independent. Resolve the fit's signer to its
    # authority-vouched principal (same binding rule as the reviewers) and require both reviewers to
    # differ. The author must itself be a vouched principal, so a forged/unvouched author fails closed.
    BIND(STRAFTER(STR(?rauthor), "kton.dev/agent/") AS ?kidA)
    GRAPH ?gba { ?ka sec:controller ?cba . ?cba ?cbpa ?pauthor . } ?gba prov:wasAttributedTo ?aa .
    FILTER(STRSTARTS(STRAFTER(STR(?ka), "kton.dev/o/"), ?kidA))
    ?aa a nk:TrustedAuthority .
    FILTER(?p1 != ?pauthor)
    FILTER(?p2 != ?pauthor)
    FILTER NOT EXISTS { ?fit gxp:reviewed ?of . ?of nk:outcome "fail" . }
    BIND("two-independent-reviews" AS ?condition)
  }
}
